# reloaded while running; some only apply to new windows and others may require
# a full restart to take effect.

theme = Gruvbox Dark Hard
# theme = GitHub Light Default
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right

clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
macos-auto-secure-input = false

keybind = cmd+f=toggle_split_zoom
# custom-shader = ~/.config/ghostty/shaders/cursor_blaze_tapered.glsl
split-divider-color = #b57614
maximize = true
font-size = 16
